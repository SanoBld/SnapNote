<Window
    x:Class="SnapNote.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="S" Modifiers="Control"       Invoked="KbSave_Invoked" />
            <KeyboardAccelerator Key="S" Modifiers="Control,Shift" Invoked="KbSaveAs_Invoked" />
            <KeyboardAccelerator Key="H" Modifiers="Control"       Invoked="KbHighlight_Invoked" />
            <KeyboardAccelerator Key="O" Modifiers="Control"       Invoked="KbOpen_Invoked" />
            <KeyboardAccelerator Key="T" Modifiers="Control"       Invoked="KbNewTab_Invoked" />
            <KeyboardAccelerator Key="W" Modifiers="Control"       Invoked="KbCloseTab_Invoked" />
        </Grid.KeyboardAccelerators>

        <!-- Zone de glissement titre -->
        <Grid x:Name="TitleBarArea" Height="32" VerticalAlignment="Top" Background="Transparent" />

        <Grid Margin="0,32,0,0">

            <!-- ══ EN-TÊTE ═══════════════════════════════════════════════════ -->
            <Grid x:Name="HeaderGrid" VerticalAlignment="Top" Height="40" Margin="12,4,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Identité -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="6">
                    <FontIcon x:Name="BrandIcon"
                              FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;"
                              FontSize="11" Foreground="#7A7A7A" VerticalAlignment="Center" />
                    <TextBlock x:Name="BrandLabel" Text="SNAPNOTE"
                               FontFamily="Cascadia Code, Segoe UI Variable Display, Segoe UI"
                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="280"
                               Foreground="#7A7A7A" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Boutons de format : Gras · Souligné · Surligné -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">

                    <Button x:Name="BtnBold" Style="{StaticResource FmtBtn}"
                            Click="BtnBold_Click" ToolTipService.ToolTip="Gras (Ctrl+B)">
                        <TextBlock x:Name="LblBold" Text="B"
                                   FontFamily="Georgia, Times New Roman"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#888888" VerticalAlignment="Center" />
                    </Button>

                    <Button x:Name="BtnUnderline" Style="{StaticResource FmtBtn}"
                            Click="BtnUnderline_Click" ToolTipService.ToolTip="Souligné (Ctrl+U)">
                        <StackPanel Width="14" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="LblUnderline" Text="U"
                                       FontFamily="Georgia, Times New Roman"
                                       FontSize="12" Foreground="#888888"
                                       HorizontalAlignment="Center" />
                            <Rectangle x:Name="UnderlineBar" Height="2" Width="12"
                                       Fill="#888888" RadiusX="1" RadiusY="1"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <SplitButton x:Name="BtnHighlight"
                                 Click="BtnHighlight_Click"
                                 Height="26" MinWidth="32" Padding="4,0,0,0"
                                 Background="Transparent" BorderThickness="0" CornerRadius="6"
                                 ToolTipService.ToolTip="Surligné (Ctrl+H)">
                        <SplitButton.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel Orientation="Horizontal" Spacing="6" Padding="4">
                                    <Button Tag="none" Style="{StaticResource SwatchBtn}"
                                            BorderBrush="#AAAAAA" Click="HighlightColor_Click"
                                            ToolTipService.ToolTip="Effacer">
                                        <Button.Content>
                                            <Line X1="0" Y1="9" X2="9" Y2="0" Stroke="#AAAAAA" StrokeThickness="1.5" />
                                        </Button.Content>
                                    </Button>
                                    <Button Tag="#FFE566" Style="{StaticResource SwatchBtn}" Background="#FFE566" BorderBrush="#D4BE40" Click="HighlightColor_Click" ToolTipService.ToolTip="Jaune" />
                                    <Button Tag="#AAEBB0" Style="{StaticResource SwatchBtn}" Background="#AAEBB0" BorderBrush="#70C078" Click="HighlightColor_Click" ToolTipService.ToolTip="Vert" />
                                    <Button Tag="#90D4F5" Style="{StaticResource SwatchBtn}" Background="#90D4F5" BorderBrush="#55AADD" Click="HighlightColor_Click" ToolTipService.ToolTip="Bleu" />
                                    <Button Tag="#FFB8CC" Style="{StaticResource SwatchBtn}" Background="#FFB8CC" BorderBrush="#E08090" Click="HighlightColor_Click" ToolTipService.ToolTip="Rose" />
                                    <Button Tag="#FFD09A" Style="{StaticResource SwatchBtn}" Background="#FFD09A" BorderBrush="#E09050" Click="HighlightColor_Click" ToolTipService.ToolTip="Orange" />
                                    <Button Tag="#D4AAEE" Style="{StaticResource SwatchBtn}" Background="#D4AAEE" BorderBrush="#A070CC" Click="HighlightColor_Click" ToolTipService.ToolTip="Violet" />
                                </StackPanel>
                            </Flyout>
                        </SplitButton.Flyout>
                        <StackPanel Width="14" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="LblHighlight" Text="A"
                                       FontFamily="Georgia, Times New Roman"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="#888888" HorizontalAlignment="Center" />
                            <Rectangle x:Name="HighlightBar" Height="3" Width="12"
                                       Fill="#FFE566" Opacity="0.7" RadiusX="1" RadiusY="1"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </SplitButton>

                </StackPanel>

                <!-- Boutons d'action : Épingler · Copier · Effacer · Paramètres -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="1">

                    <Button x:Name="BtnPin" Style="{StaticResource IconBtn}"
                            Click="BtnPin_Click" ToolTipService.ToolTip="Épingler (toujours au-dessus)">
                        <!-- Segoe Fluent Icons : Pin -->
                        <FontIcon x:Name="PinIcon" FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE718;" FontSize="13" Foreground="#888888" />
                    </Button>

                    <Button Style="{StaticResource IconBtn}" Click="BtnCopy_Click"
                            ToolTipService.ToolTip="Copier tout">
                        <!-- Segoe Fluent Icons : Copy -->
                        <FontIcon x:Name="CopyIcon" FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE8C8;" FontSize="13" Foreground="#888888" />
                    </Button>

                    <Button Style="{StaticResource IconBtn}" Click="BtnClear_Click"
                            ToolTipService.ToolTip="Effacer l'onglet">
                        <!-- Segoe Fluent Icons : Delete -->
                        <FontIcon x:Name="ClearIcon" FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE74D;" FontSize="13" Foreground="#888888" />
                    </Button>

                    <Button x:Name="BtnSettings" Style="{StaticResource IconBtn}"
                            Click="BtnSettings_Click" ToolTipService.ToolTip="Paramètres">
                        <!-- Segoe Fluent Icons : Settings -->
                        <FontIcon x:Name="SettingsIcon" FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE713;" FontSize="13" Foreground="#888888" />
                    </Button>

                </StackPanel>
            </Grid>

            <!-- Séparateur 1 -->
            <Rectangle x:Name="Divider" Height="1" VerticalAlignment="Top"
                       Margin="0,44,0,0" Fill="#888888" Opacity="0.10" />

            <!-- ══ BARRE D'ONGLETS ═════════════════════════════════════════ -->
            <Grid x:Name="TabStripGrid" VerticalAlignment="Top" Height="30" Margin="0,45,0,0">

                <!-- Onglets scrollables -->
                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,32,0">
                    <StackPanel x:Name="TabStrip"
                                Orientation="Horizontal" Spacing="2"
                                Padding="8,2,4,2" VerticalAlignment="Center" />
                </ScrollViewer>

                <!-- Nouvel onglet -->
                <Button x:Name="BtnAddTab"
                        HorizontalAlignment="Right" Width="28" Height="28"
                        Style="{StaticResource IconBtn}"
                        Click="BtnAddTab_Click"
                        ToolTipService.ToolTip="Nouvel onglet (Ctrl+T)">
                    <FontIcon x:Name="AddTabIcon"
                              FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;"
                              FontSize="11" Foreground="#888888" />
                </Button>
            </Grid>

            <!-- Séparateur 2 -->
            <Rectangle x:Name="Divider2" Height="1" VerticalAlignment="Top"
                       Margin="0,75,0,0" Fill="#888888" Opacity="0.08" />

            <!-- ══ CONTENU ONGLETS ══════════════════════════════════════════ -->
            <Grid x:Name="TabContent" Margin="4,76,4,36" VerticalAlignment="Stretch" />

            <!-- ══ OVERLAY PARAMÈTRES (plein écran, comme un onglet) ═══════ -->
            <Grid x:Name="SettingsOverlay"
                  Margin="0,76,0,36"
                  Visibility="Collapsed">
                <Grid.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="8" IsStaggeringEnabled="False" />
                    </TransitionCollection>
                </Grid.Transitions>

                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="20,14,20,20" Spacing="0" MaxWidth="440">

                        <!-- ── En-tête paramètres ── -->
                        <Grid Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="10" Width="36" Height="36">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;"
                                              FontSize="16"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Paramètres"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="SnapNote v1.2"
                                               FontFamily="Cascadia Code" FontSize="9"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,14" />

                        <!-- ── FICHIER ── -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,10">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A5;"
                                      FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="FICHIER" FontFamily="Cascadia Code" FontSize="8"
                                       FontWeight="SemiBold" CharacterSpacing="200"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Spacing="6" Margin="0,0,0,0">

                            <Button x:Name="BtnOpenFile" Click="BtnOpen_Click"
                                    Style="{StaticResource SettingsRowBtn}"
                                    ToolTipService.ToolTip="Ctrl+O">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                            CornerRadius="6" Width="28" Height="28">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8E5;"
                                                  FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Ouvrir un fichier…" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Text="RTF · TXT · MD" FontFamily="Cascadia Code"
                                                   FontSize="9" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSaveAsFile" Click="BtnSaveAs_Click"
                                    Style="{StaticResource SettingsRowBtn}"
                                    ToolTipService.ToolTip="Ctrl+Shift+S">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                            CornerRadius="6" Width="28" Height="28">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE792;"
                                                  FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Enregistrer sous…" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Text="RTF · TXT" FontFamily="Cascadia Code"
                                                   FontSize="9" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,14,0,14" />

                        <!-- ── TYPOGRAPHIE ── -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D2;"
                                      FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="TYPOGRAPHIE" FontFamily="Cascadia Code" FontSize="8"
                                       FontWeight="SemiBold" CharacterSpacing="200"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Police" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="FontCombo" HorizontalAlignment="Stretch"
                                  CornerRadius="8" SelectionChanged="FontCombo_Changed" />

                        <Grid Margin="0,14,0,6">
                            <TextBlock Text="Taille" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <Border HorizontalAlignment="Right"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="6" Padding="8,3">
                                <TextBlock x:Name="SizeLbl" Text="14"
                                           FontFamily="Cascadia Code" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </Grid>

                        <Slider x:Name="SizeSlider" Minimum="10" Maximum="28" Value="14"
                                StepFrequency="1" Margin="0,0,0,12"
                                ValueChanged="SizeSlider_Changed" />

                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="10" Padding="14,12" Margin="0,0,0,2">
                            <TextBlock x:Name="FontPreview"
                                       Text="Aperçu — 0123 abc ABC"
                                       FontFamily="Cascadia Code, Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,16,0,14" />

                        <!-- ── RACCOURCIS ── -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE765;"
                                      FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="RACCOURCIS" FontFamily="Cascadia Code" FontSize="8"
                                       FontWeight="SemiBold" CharacterSpacing="200"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+T" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Nouvel onglet"  FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+W" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Fermer onglet"  FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="2" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+O" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Ouvrir"          FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="3" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+S" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Sauvegarder"     FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="4" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+⇧+S" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Enreg. sous"     FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="5" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+B" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Gras"            FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="6" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+U" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Souligné"        FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                            <Border Grid.Row="7" Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl+H" FontFamily="Cascadia Code" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></Border>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="Surligné"        FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,20,0,16" />

                        <!-- ── Pied ── -->
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;"
                                          FontSize="9" Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="SnapNote v1.2" FontFamily="Cascadia Code" FontSize="9"
                                           Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                            </StackPanel>
                            <TextBlock Text="fait avec soin" FontFamily="Cascadia Code" FontSize="8"
                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ══ PIED DE PAGE ════════════════════════════════════════════ -->
            <Grid x:Name="FooterGrid" VerticalAlignment="Bottom" Margin="12,0,12,6" Height="24">

                <!-- Palette de couleurs -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                    <Button Tag="transparent" Style="{StaticResource SwatchBtn}" BorderBrush="#AAAAAA"
                            Click="Swatch_Click" ToolTipService.ToolTip="Mica (transparent)">
                        <Button.Content>
                            <Line X1="0" Y1="9" X2="9" Y2="0" Stroke="#AAAAAA" StrokeThickness="1.5" />
                        </Button.Content>
                    </Button>
                    <Button Tag="#F8F8F8" Style="{StaticResource SwatchBtn}" Background="#F8F8F8" BorderBrush="#DDDDDD" Click="Swatch_Click" ToolTipService.ToolTip="Blanc" />
                    <Button Tag="#F5EDD6" Style="{StaticResource SwatchBtn}" Background="#F5EDD6" BorderBrush="#E0D0A0" Click="Swatch_Click" ToolTipService.ToolTip="Crème" />
                    <Button Tag="#2C2C2C" Style="{StaticResource SwatchBtn}" Background="#2C2C2C" BorderBrush="#444444" Click="Swatch_Click" ToolTipService.ToolTip="Anthracite" />
                    <Button Tag="#101010" Style="{StaticResource SwatchBtn}" Background="#101010" BorderBrush="#333333" Click="Swatch_Click" ToolTipService.ToolTip="Noir" />
                    <Button Tag="#1A2333" Style="{StaticResource SwatchBtn}" Background="#1A2333" BorderBrush="#2A3D5A" Click="Swatch_Click" ToolTipService.ToolTip="Nuit" />
                </StackPanel>

                <!-- Compact + Statut -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="6">

                    <!-- Bouton mode compact -->
                    <Button x:Name="BtnCompact" Style="{StaticResource IconBtn}"
                            Width="22" Height="22"
                            Click="BtnCompact_Click"
                            ToolTipService.ToolTip="Mode prise de note rapide">
                        <FontIcon x:Name="CompactIcon"
                                  FontFamily="Segoe MDL2 Assets" Glyph="&#xE922;"
                                  FontSize="10" Foreground="#BBBBBB" />
                    </Button>

                    <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#BBBBBB" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText" Text="prêt"
                               FontFamily="Cascadia Code" FontSize="10"
                               CharacterSpacing="80" Foreground="#BBBBBB"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Window>
