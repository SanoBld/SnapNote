<Application
    x:Class="SnapNote.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ══ RichEditBox propre, sans focus ring ══════════════════════ -->
            <Style x:Key="CleanRichEditStyle" TargetType="RichEditBox">
                <Setter Property="BorderThickness"       Value="0" />
                <Setter Property="Background"            Value="Transparent" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
                <Setter Property="FocusVisualMargin"     Value="0" />
                <Setter Property="Padding"               Value="16,10,16,10" />
            </Style>

            <!-- ══ Bouton icône — Windows 11 Fluent ════════════════════════ -->
            <Style x:Key="IconBtn" TargetType="Button">
                <Setter Property="Background"      Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding"         Value="4" />
                <Setter Property="Width"           Value="32" />
                <Setter Property="Height"          Value="32" />
                <Setter Property="CornerRadius"    Value="8" />
            </Style>

            <!-- ══ Bouton format (B U H) ════════════════════════════════════ -->
            <Style x:Key="FmtBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
                <Setter Property="Width"  Value="28" />
                <Setter Property="Height" Value="28" />
            </Style>

            <!-- ══ Swatch couleur ════════════════════════════════════════════ -->
            <Style x:Key="SwatchBtn" TargetType="Button">
                <Setter Property="Width"           Value="18" />
                <Setter Property="Height"          Value="18" />
                <Setter Property="Padding"         Value="0" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius"    Value="12" />
                <Setter Property="Background"      Value="Transparent" />
            </Style>

            <!-- ══ Bouton onglet ══════════════════════════════════════════════ -->
            <Style x:Key="TabBtn" TargetType="Button">
                <Setter Property="Background"      Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Height"          Value="26" />
                <Setter Property="MinWidth"        Value="70" />
                <Setter Property="Padding"         Value="8,0,4,0" />
                <Setter Property="CornerRadius"    Value="6" />
            </Style>

            <!-- ══ Bouton ligne paramètres ══════════════════════════════════ -->
            <Style x:Key="SettingsRowBtn" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="CornerRadius"        Value="10" />
                <Setter Property="Padding"             Value="14,11" />
                <Setter Property="Background"          Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                <Setter Property="BorderThickness"     Value="0" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
